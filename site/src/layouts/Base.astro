---
import Analytics from "@vercel/analytics/astro";

interface Props {
  title: string;
  description?: string;
  path?: string;
}

const {
  title,
  description = "Lightweight TypeScript logging library that treats logs as stories. Zero dependencies. One record per story.",
  path = "",
} = Astro.props;

const siteUrl = "https://storyteller.lovelaces.io";
const canonicalUrl = `${siteUrl}${path}`;
const ogImageUrl = `${siteUrl}/og-image.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph (Facebook, LinkedIn, Slack, Discord) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Storyteller by Lovelaces" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Theme color (CRT green) -->
    <meta name="theme-color" content="#4ade80" />
    <meta name="color-scheme" content="dark" />

    <!-- Keywords -->
    <meta name="keywords" content="logging, TypeScript, structured logging, storyteller, developer tools, zero dependencies, npm package" />
    <meta name="author" content="Lovelaces" />

    <link rel="icon" type="image/svg+xml" href="/lovelaces-logo.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <div class="container">
      <nav>
        <a href="/" class="logo">
          <img src="/lovelaces-logo.svg" alt="Lovelaces" />
          Storyteller
        </a>
        <div class="nav-links">
          <a href="/docs">Docs</a>
          <a href="https://github.com/lovelaces-io/storyteller">GitHub</a>
          <a href="https://www.npmjs.com/package/@lovelaces-io/storyteller">npm</a>
        </div>
      </nav>
    </div>

    <slot />

    <Analytics />

    <footer>
      <div class="container">
        <div class="footer-links">
          <a href="https://github.com/lovelaces-io/storyteller">GitHub</a>
          <a href="https://www.npmjs.com/package/@lovelaces-io/storyteller">npm</a>
          <a href="/docs">Documentation</a>
          <a href="https://lovelaces.io">lovelaces.io</a>
        </div>
        <p>Happy logging!</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
