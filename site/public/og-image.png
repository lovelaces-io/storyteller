<svg width="1200" height="630" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&amp;family=Inter:wght@600;700&amp;display=swap');
    </style>
  </defs>

  <!-- Background -->
  <rect width="1200" height="630" fill="#0a0f0a"/>

  <!-- Subtle grid pattern -->
  <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
    <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#1a2e1a" stroke-width="0.5"/>
  </pattern>
  <rect width="1200" height="630" fill="url(#grid)"/>

  <!-- Green glow accent -->
  <ellipse cx="600" cy="315" rx="400" ry="200" fill="#4ade80" opacity="0.04"/>

  <!-- Package name -->
  <text x="100" y="200" font-family="IBM Plex Mono, monospace" font-size="24" font-weight="500" fill="#4ade80">@lovelaces-io/storyteller</text>

  <!-- Main heading -->
  <text x="100" y="290" font-family="Inter, sans-serif" font-size="64" font-weight="700" fill="#f0fff0">Your logs should</text>
  <text x="100" y="365" font-family="Inter, sans-serif" font-size="64" font-weight="700" fill="#f0fff0">tell a story</text>

  <!-- Subheading -->
  <text x="100" y="430" font-family="Inter, sans-serif" font-size="24" font-weight="600" fill="#7a9a7a">Zero dependencies. TypeScript-first. One record per story.</text>

  <!-- Level indicators -->
  <circle cx="120" cy="520" r="8" fill="#4ade80"/>
  <text x="140" y="526" font-family="IBM Plex Mono, monospace" font-size="20" font-weight="500" fill="#4ade80">tell</text>

  <circle cx="270" cy="520" r="8" fill="#f59e0b"/>
  <text x="290" y="526" font-family="IBM Plex Mono, monospace" font-size="20" font-weight="500" fill="#f59e0b">warn</text>

  <circle cx="420" cy="520" r="8" fill="#ef4444"/>
  <text x="440" y="526" font-family="IBM Plex Mono, monospace" font-size="20" font-weight="500" fill="#ef4444">oops</text>

  <!-- Terminal snippet on right -->
  <rect x="700" y="170" width="420" height="280" rx="8" fill="#0f1a0f" stroke="#1a2e1a"/>
  <circle cx="725" cy="195" r="5" fill="#2a7a3a"/>
  <circle cx="743" cy="195" r="5" fill="#2a7a3a"/>
  <circle cx="761" cy="195" r="5" fill="#2a7a3a"/>
  <text x="725" y="240" font-family="IBM Plex Mono, monospace" font-size="16" fill="#7a9a7a">story.note("Cart validated");</text>
  <text x="725" y="270" font-family="IBM Plex Mono, monospace" font-size="16" fill="#7a9a7a">story.note("Card charged");</text>
  <text x="725" y="310" font-family="IBM Plex Mono, monospace" font-size="16" fill="#4ade80">story.tell("Payment complete");</text>
  <text x="725" y="360" font-family="IBM Plex Mono, monospace" font-size="14" fill="#5a7a5a">// one record. the whole story.</text>

  <!-- Lovelaces branding -->
  <text x="1020" y="526" font-family="Inter, sans-serif" font-size="18" font-weight="600" fill="#5a7a5a">lovelaces.io</text>
</svg>
